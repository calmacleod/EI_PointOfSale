# Secrets defined here are available for reference under registry/password, env/secret, builder/secrets,
# and accessories/*/env/secret in config/deploy.yml. All secrets should be pulled from either
# password manager, ENV, or a file. DO NOT ENTER RAW CREDENTIALS HERE! This file needs to be safe for git.

# Example of extracting secrets from 1password (or another compatible pw manager)
# SECRETS=$(kamal secrets fetch --adapter 1password --account your-account --from Vault/Item RAILS_MASTER_KEY POSTGRES_PASSWORD GARAGE_ACCESS_KEY GARAGE_SECRET_KEY)
# RAILS_MASTER_KEY=$(kamal secrets extract RAILS_MASTER_KEY ${SECRETS})
# POSTGRES_PASSWORD=$(kamal secrets extract POSTGRES_PASSWORD ${SECRETS})
# GARAGE_ACCESS_KEY=$(kamal secrets extract GARAGE_ACCESS_KEY ${SECRETS})
# GARAGE_SECRET_KEY=$(kamal secrets extract GARAGE_SECRET_KEY ${SECRETS})

# Read Rails master key from file (never check config/master.key into git!)
RAILS_MASTER_KEY=$(cat config/credentials/production.key)

# Load deployment secrets from .kamal/secrets.env (gitignored).
# Copy .kamal/secrets.env.example to .kamal/secrets.env and fill in values.
# source "$(dirname "$0")/secrets.env"

SECRETS=$(kamal secrets fetch --adapter bitwarden-sm f96702e4-3b6b-4918-815f-b41200cbeba3/all)

# Server
SERVER_IP_ADDR=$(kamal secrets extract KAMAL_SERVER_IP ${SECRETS})

# Garage
GARAGE_ACCESS_KEY=$(kamal secrets extract KAMAL_GARAGE_ACCESS_KEY ${SECRETS})
GARAGE_SECRET_KEY=$(kamal secrets extract KAMAL_GARAGE_SECRET_KEY ${SECRETS})

# Postgres
# DATABASE_HOST=ei-point-of-sale-db:5432
POSTGRES_PASSWORD=$(kamal secrets extract KAMAL_POSTGRES_PASSWORD ${SECRETS})
DATABASE_URL="postgresql://postgres:${POSTGRES_PASSWORD}@ei-point-of-sale-db:5432/ei-point_of_sale_production"
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=${POSTGRES_PASSWORD}

# New Relic
NEW_RELIC_LICENSE_KEY=$$(kamal secrets extract NEW_RELIC_LICENSE_KEY ${SECRETS})

# Sentry
SENTRY_DSN=$(kamal secrets extract SENTRY_DSN ${SECRETS})

