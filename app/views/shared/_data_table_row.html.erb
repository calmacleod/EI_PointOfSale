<tr>
  <% column_renderers.each do |col, renderer| %>
    <td class="whitespace-nowrap px-3 py-1.5 text-sm text-body" data-column="<%= col.key %>">
      <%= renderer.call(data_table_row) if renderer %>
    </td>
  <% end %>
  <td class="px-3 py-1.5 text-right text-sm" data-column="actions">
    <%= actions_renderer.call(data_table_row) if actions_renderer %>
  </td>
</tr>
