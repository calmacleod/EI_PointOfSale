<% content_for :title, "Users" %>
<% content_for :breadcrumbs do %>
  <li><%= link_to "Dashboard", root_path, class: "text-muted hover:text-body transition-colors" %></li>
  <li aria-hidden="true" class="flex items-center text-muted/40"><svg class="h-3 w-3" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"/></svg></li>
  <li><%= link_to "Admin settings", admin_settings_path, class: "text-muted hover:text-body transition-colors" %></li>
  <li aria-hidden="true" class="flex items-center text-muted/40"><svg class="h-3 w-3" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"/></svg></li>
  <li aria-current="page" class="text-body font-medium">Users</li>
<% end %>

<div class="lg:flex lg:min-h-0 lg:flex-1 lg:flex-col">
  <%= render "shared/page_header", title: "Users" do %>
    <%= link_to "Add user", new_admin_user_path,
        class: "inline-flex min-h-[30px] items-center justify-center rounded-md bg-accent px-2.5 py-1 text-sm font-semibold text-[color:var(--color-page)] hover:bg-[var(--color-accent-hover)]",
        data: { turbo_prefetch: true } %>
  <% end %>

  <div class="mt-2 flex flex-col gap-2 lg:min-h-0 lg:flex-1">
    <%= render "shared/filter_bar", config: @filter_config, saved_queries: @saved_queries %>

    <%= render "shared/data_table", config: @filter_config, records: @users, pagy: @pagy,
               empty_message: "No users found." do |t| %>
      <%= t.cell(:name) { |user| link_to((user.name.presence || "—"), admin_user_path(user), class: "font-medium text-accent hover:underline", data: { turbo_frame: "_top", turbo_prefetch: true }) } %>
      <%= t.cell(:email_address) { |user| link_to user.email_address, admin_user_path(user), class: "text-accent hover:underline", data: { turbo_frame: "_top", turbo_prefetch: true } } %>
      <%= t.cell(:type) { |user| user.type } %>
      <%= t.cell(:phone) { |user| user.phone.presence || "—" } %>
      <%= t.cell(:active) { |user| user.active? ? "Yes" : "No" } %>
      <%= t.cell(:created_at) { |user| local_time(user.created_at, format: :short) } %>
      <%= t.cell(:updated_at) { |user| local_time(user.updated_at, format: :short) } %>
      <%= t.cell(:actions) { |user| link_to("Edit", edit_admin_user_path(user), class: "font-medium text-accent hover:opacity-80", data: { turbo_frame: "_top", turbo_prefetch: true }) } %>
    <% end %>
  </div>
</div>
