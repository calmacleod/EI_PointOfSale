<% content_for :title, "Suppliers" %>
<% content_for :breadcrumbs do %>
  <li><%= link_to "Dashboard", root_path, class: "text-muted hover:text-body transition-colors" %></li>
  <li aria-hidden="true" class="flex items-center text-muted/40"><svg class="h-3 w-3" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"/></svg></li>
  <li><%= link_to "Admin settings", admin_settings_path, class: "text-muted hover:text-body transition-colors" %></li>
  <li aria-hidden="true" class="flex items-center text-muted/40"><svg class="h-3 w-3" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"/></svg></li>
  <li aria-current="page" class="text-body font-medium">Suppliers</li>
<% end %>

<div class="lg:flex lg:min-h-0 lg:flex-1 lg:flex-col">
  <%= render "shared/page_header", title: "Suppliers" do %>
    <%= link_to "Add supplier", new_admin_supplier_path,
        class: "inline-flex min-h-[30px] items-center justify-center rounded-md bg-accent px-2.5 py-1 text-sm font-semibold text-[color:var(--color-page)] hover:bg-[var(--color-accent-hover)]",
        data: { turbo_prefetch: true } %>
  <% end %>

  <div class="mt-2 flex flex-col gap-2 lg:min-h-0 lg:flex-1">
    <%= render "shared/filter_bar", config: @filter_config, saved_queries: @saved_queries %>

    <%= render "shared/data_table", config: @filter_config, records: @suppliers, pagy: @pagy,
               empty_message: "No suppliers yet. Add one to get started." do |t| %>
      <%= t.cell(:name) { |supplier| link_to supplier.name, admin_supplier_path(supplier), class: "font-medium text-accent hover:underline", data: { turbo_frame: "_top", turbo_prefetch: true } } %>
      <%= t.cell(:phone) { |supplier| supplier.phone.presence || "—" } %>
      <%= t.cell(:created_at) { |supplier| local_time(supplier.created_at, format: :short) } %>
      <%= t.cell(:updated_at) { |supplier| local_time(supplier.updated_at, format: :short) } %>
      <%= t.cell(:actions) { |supplier| link_to("Edit", edit_admin_supplier_path(supplier), class: "font-medium text-accent hover:opacity-80", data: { turbo_frame: "_top", turbo_prefetch: true }) } %>
    <% end %>
  </div>
</div>
