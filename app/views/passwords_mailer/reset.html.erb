<h1 style="margin: 0 0 8px 0; font-size: 22px; font-weight: 700; color: #1a1a1a; line-height: 28px;">
  Reset your password
</h1>
<p style="margin: 0 0 24px 0; font-size: 15px; color: #6b6b6b; line-height: 22px;">
  Hi <%= @user.name || @user.email_address %>, we received a request to reset your password. Click the button below to choose a new one.
</p>
<!-- Button -->
<table role="presentation" cellpadding="0" cellspacing="0" style="margin: 0 0 24px 0;">
  <tr>
    <td style="background-color: #0d9488; border-radius: 8px;">
      <a href="<%= edit_password_url(@user.password_reset_token) %>"
         style="display: inline-block; padding: 12px 28px; font-size: 15px; font-weight: 600; color: #ffffff; text-decoration: none; border-radius: 8px;">
        Reset password
      </a>
    </td>
  </tr>
</table>
<!-- Expiry notice -->
<table role="presentation" cellpadding="0" cellspacing="0" width="100%" style="margin: 0 0 0 0;">
  <tr>
    <td style="background-color: #f7f7f7; border-radius: 8px; padding: 12px 16px;">
      <p style="margin: 0; font-size: 13px; color: #6b6b6b; line-height: 20px;">
        This link will expire in <strong style="color: #1a1a1a;"><%= distance_of_time_in_words(0, @user.password_reset_token_expires_in) %></strong>.
        If you didn't request this, you can safely ignore this email.
      </p>
    </td>
  </tr>
</table>
