<div id="order_payments_panel" class="border-b border-theme p-4">
  <h3 class="text-xs font-semibold uppercase tracking-wider text-muted mb-2">Payments</h3>

  <% order.order_payments.each do |payment| %>
    <div class="flex items-center justify-between rounded-md border border-theme bg-surface px-3 py-1.5 mb-1.5 text-xs">
      <div>
        <span class="font-medium text-body"><%= payment.display_method %></span>
        <% if payment.reference.present? %>
          <span class="text-muted">(ref: <%= payment.reference %>)</span>
        <% end %>
        <% if payment.cash? && payment.amount_tendered.present? %>
          <div class="text-[10px] text-muted mt-0.5">
            Tendered: <%= number_to_currency(payment.amount_tendered) %> |
            Change: <%= number_to_currency(payment.change_given || 0) %>
          </div>
        <% end %>
      </div>
      <div class="flex items-center gap-2">
        <span class="font-medium text-body"><%= number_to_currency(payment.amount) %></span>
        <% if order.draft? %>
          <%= button_to order_payment_path(payment), method: :delete, class: "text-muted hover:text-red-500", data: { turbo_stream: true } do %>
            <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
          <% end %>
        <% end %>
      </div>
    </div>
  <% end %>

  <% if local_assigns[:payment_error].present? %>
    <div class="mb-2 rounded-md bg-red-50 border border-red-200 px-3 py-2 text-xs text-red-700">
      <%= payment_error %>
    </div>
  <% end %>

  <% if order.draft? && order.order_lines.any? %>
    <button type="button"
            class="mt-2 w-full rounded-md border border-theme bg-surface px-3 py-2 text-xs font-medium text-body hover:bg-(--color-border) transition"
            onclick="document.getElementById('payment_modal').classList.remove('hidden')">
      <svg class="inline h-3.5 w-3.5 mr-1 -mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
      Add Payment
    </button>
  <% end %>
</div>
