<div id="payment_modal" class="hidden fixed inset-0 z-50" role="dialog" aria-modal="true"
     data-controller="payment-form"
     data-payment-form-remaining-value="<%= order.amount_remaining %>"
     data-payment-form-gc-lookup-url-value="<%= gift_certificate_lookup_path %>">
  <div class="fixed inset-0 bg-black/50" data-action="click->payment-form#closeModal"></div>
  <div class="fixed inset-0 flex items-start justify-center pt-[15vh] p-4" style="pointer-events: none;">
    <div class="w-full max-w-md rounded-xl bg-surface shadow-2xl overflow-hidden" style="pointer-events: auto;">
      <%# Header %>
      <div class="flex items-center justify-between border-b border-theme px-5 py-3 bg-surface-alt">
        <h3 class="text-sm font-semibold text-body">Add Payment</h3>
        <div class="flex items-center gap-3">
          <span class="text-xs text-muted">Remaining: <strong class="text-body"><%= number_to_currency(order.amount_remaining) %></strong></span>
          <button type="button" class="text-muted hover:text-body transition" data-action="click->payment-form#closeModal">
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
          </button>
        </div>
      </div>

      <%# Body %>
      <div class="p-5">
        <%= form_with url: order_order_payments_path(order), class: "space-y-3", data: { turbo_stream: true, action: "submit->payment-form#validateBeforeSubmit" } do |f| %>
          <input type="hidden" name="order_payment[payment_method]" value="<%= OrderPayment.payment_methods.keys.first %>"
                 data-payment-form-target="methodInput">

          <%# Payment method buttons %>
          <div>
            <label class="block text-[11px] font-medium text-muted mb-1.5">Payment Method</label>
            <div class="flex flex-wrap gap-1.5" data-payment-form-target="methodButtons">
              <% OrderPayment.payment_methods.keys.each_with_index do |method, index| %>
                <button type="button"
                        class="rounded-md px-3 py-2 text-xs font-medium border transition flex-1 min-w-20
                               <%= index == 0 ? 'bg-accent text-white border-accent' : 'bg-surface text-muted border-theme hover:bg-[var(--color-border)]' %>"
                        data-method="<%= method %>"
                        data-payment-form-target="methodButton"
                        data-action="click->payment-form#selectMethod">
                  <%= method.humanize %>
                </button>
              <% end %>
            </div>
          </div>

          <%# Amount %>
          <div>
            <label class="block text-[11px] font-medium text-muted mb-1">Amount</label>
            <input type="number" name="order_payment[amount]" step="0.01" min="0" autocomplete="off"
                   value="<%= order.amount_remaining %>"
                   class="input-field w-full text-sm"
                   placeholder="Amount"
                   data-payment-form-target="amountInput"
                   required>
          </div>

          <%# Cash tendered section (shown only for cash) %>
          <div data-payment-form-target="cashSection" class="hidden space-y-2">
            <div>
              <label class="block text-[11px] font-medium text-muted mb-1">Amount Tendered</label>
              <input type="number" name="order_payment[amount_tendered]" step="0.01" min="0" autocomplete="off"
                     class="input-field w-full text-sm"
                     placeholder="Amount tendered"
                     data-payment-form-target="tenderedInput"
                     data-action="input->payment-form#calculateChange">
            </div>
            <div class="flex justify-between rounded-md bg-surface-alt px-3 py-2 text-xs">
              <span class="text-muted">Change due:</span>
              <span class="font-bold text-body" data-payment-form-target="changeDisplay">$0.00</span>
            </div>
          </div>

          <%# Gift certificate balance display %>
          <div data-payment-form-target="gcBalanceDisplay" class="hidden">
            <div class="flex justify-between rounded-md bg-green-50 border border-green-200 px-3 py-2 text-xs">
              <span class="text-green-700">Available balance:</span>
              <span class="font-bold text-green-700" data-payment-form-target="gcBalanceAmount"></span>
            </div>
          </div>

          <%# GC not found message %>
          <div data-payment-form-target="gcNotFound" class="hidden text-xs text-red-600 px-1">
            Gift certificate not found or not active.
          </div>

          <%# Reference / GC code field %>
          <div>
            <label class="block text-[11px] font-medium text-muted mb-1">Reference</label>
            <input type="text" name="order_payment[reference]"
                   placeholder="Reference (optional)"
                   autocomplete="off"
                   class="input-field w-full text-sm"
                   data-payment-form-target="referenceInput"
                   data-action="input->payment-form#onReferenceInput">
          </div>

          <button type="submit" class="w-full rounded-lg bg-accent px-4 py-2.5 text-sm font-semibold text-white hover:bg-(--color-accent-hover) transition">
            Record Payment
          </button>
        <% end %>
      </div>

      <%# Adjust modal (nested inside payment modal) %>
      <div data-payment-form-target="adjustModal" class="hidden fixed inset-0 z-60" role="dialog">
        <div class="fixed inset-0 bg-black/50" data-action="click->payment-form#closeAdjustModal"></div>
        <div class="fixed inset-0 flex items-center justify-center p-4" style="pointer-events: none;">
          <div class="w-full max-w-sm rounded-xl bg-surface shadow-2xl overflow-hidden" style="pointer-events: auto;">
            <div class="bg-amber-50 px-5 py-4 border-b border-amber-200">
              <div class="flex items-start gap-3">
                <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-amber-100">
                  <svg class="h-4 w-4 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
                </div>
                <div>
                  <h3 class="text-sm font-semibold text-amber-900">Adjust Payment Amount?</h3>
                  <p class="mt-1 text-xs text-amber-700" data-payment-form-target="adjustModalMessage">
                    The amount tendered is less than the payment amount.
                  </p>
                </div>
              </div>
            </div>
            <div class="flex justify-end gap-2 bg-surface px-5 py-3">
              <button type="button"
                      data-action="click->payment-form#closeAdjustModal"
                      class="rounded-lg border border-theme px-3.5 py-1.5 text-xs font-medium text-body hover:bg-(--color-border) transition">
                Cancel
              </button>
              <button type="button"
                      data-action="click->payment-form#confirmAdjustAmount"
                      class="rounded-lg bg-accent px-3.5 py-1.5 text-xs font-semibold text-white hover:bg-(--color-accent-hover) transition">
                Adjust & Record
              </button>
            </div>
          </div>
        </div>
      </div>
      <%# Overpayment confirmation modal (nested inside payment modal) %>
      <div data-payment-form-target="overpayModal" class="hidden fixed inset-0 z-60" role="dialog">
        <div class="fixed inset-0 bg-black/50" data-action="click->payment-form#closeOverpayModal"></div>
        <div class="fixed inset-0 flex items-center justify-center p-4" style="pointer-events: none;">
          <div class="w-full max-w-sm rounded-xl bg-surface shadow-2xl overflow-hidden" style="pointer-events: auto;">
            <div class="bg-red-50 px-5 py-4 border-b border-red-200">
              <div class="flex items-start gap-3">
                <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-red-100">
                  <svg class="h-4 w-4 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
                </div>
                <div>
                  <h3 class="text-sm font-semibold text-red-900">Overpayment Warning</h3>
                  <p class="mt-1 text-xs text-red-700" data-payment-form-target="overpayModalMessage">
                    This payment exceeds the remaining balance.
                  </p>
                </div>
              </div>
            </div>
            <div class="flex justify-end gap-2 bg-surface px-5 py-3">
              <button type="button"
                      data-action="click->payment-form#closeOverpayModal"
                      class="rounded-lg border border-theme px-3.5 py-1.5 text-xs font-medium text-body hover:bg-(--color-border) transition">
                Cancel
              </button>
              <button type="button"
                      data-action="click->payment-form#confirmOverpay"
                      class="rounded-lg bg-red-600 px-3.5 py-1.5 text-xs font-semibold text-white hover:bg-red-700 transition">
                Confirm Overpayment
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
