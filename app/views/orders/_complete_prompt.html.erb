<div id="complete_prompt_modal" class="fixed inset-0 z-70" role="dialog" aria-modal="true">
  <div class="fixed inset-0 bg-black/50" onclick="document.getElementById('complete_prompt_modal').remove()"></div>
  <div class="fixed inset-0 flex items-start justify-center pt-[22vh] p-4" style="pointer-events: none;">
    <div class="w-full max-w-sm rounded-xl border border-green-200 bg-surface shadow-2xl overflow-hidden" style="pointer-events: auto;">
      <div class="bg-green-50 px-5 py-4">
        <div class="flex items-start gap-3">
          <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-green-100">
            <svg class="h-4 w-4 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
          </div>
          <div>
            <h3 class="text-sm font-semibold text-green-900">Order Fully Paid</h3>
            <p class="mt-1 text-xs text-green-700">
              This order has been paid in full. Would you like to complete it now?
            </p>
          </div>
        </div>
      </div>
      <div class="flex justify-end gap-2 border-t border-green-200 bg-surface px-5 py-3">
        <button type="button"
                onclick="document.getElementById('complete_prompt_modal').remove()"
                class="rounded-lg border border-theme px-3.5 py-1.5 text-xs font-medium text-body hover:bg-(--color-border) transition">
          Not Yet
        </button>
        <%= button_to "Complete Order", complete_order_path(order), method: :post,
            class: "rounded-lg bg-green-600 px-3.5 py-1.5 text-xs font-semibold text-white hover:bg-green-700 transition" %>
      </div>
    </div>
  </div>
</div>
