<% content_for :title, "Customers" %>
<% content_for :breadcrumbs do %>
  <li><%= link_to "Dashboard", root_path, class: "text-muted hover:text-body transition-colors" %></li>
  <li aria-hidden="true" class="flex items-center text-muted/40"><svg class="h-3 w-3" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"/></svg></li>
  <li aria-current="page" class="text-body font-medium">Customers</li>
<% end %>

<div class="lg:flex lg:min-h-0 lg:flex-1 lg:flex-col">
  <%= render "shared/page_header", title: "Customers" do %>
    <% if can? :create, Customer %>
      <%= link_to "Add customer", new_customer_path,
          class: "inline-flex min-h-[30px] items-center justify-center rounded-md bg-accent px-2.5 py-1 text-sm font-semibold text-[color:var(--color-page)] hover:bg-[var(--color-accent-hover)]",
          data: { turbo_prefetch: true } %>
    <% end %>
  <% end %>

  <div class="mt-2 flex flex-col gap-2 lg:min-h-0 lg:flex-1">
    <%= render "shared/filter_bar", config: @filter_config, saved_queries: @saved_queries %>

    <%= render "shared/data_table", config: @filter_config, records: @customers, pagy: @pagy,
               empty_message: "No customers yet. Add one to get started." do |t| %>
      <%= t.cell(:name) { |customer| can?(:read, customer) ? link_to(customer.name, customer_path(customer), class: "font-medium text-accent hover:underline", data: { turbo_frame: "_top", turbo_prefetch: true }) : customer.name } %>
      <%= t.cell(:member_number) { |customer| customer.member_number.presence || "—" } %>
      <%= t.cell(:phone) { |customer| customer.phone.presence || "—" } %>
      <%= t.cell(:email) { |customer| customer.email.presence || "—" } %>
      <%= t.cell(:city) { |customer| customer.city.presence || "—" } %>
      <%= t.cell(:province) { |customer| customer.province.presence || "—" } %>
      <%= t.cell(:active) { |customer| customer.active? ? "Active" : "Inactive" } %>
      <%= t.cell(:created_at) { |customer| local_time(customer.created_at, format: :short) } %>
      <%= t.cell(:updated_at) { |customer| local_time(customer.updated_at, format: :short) } %>
      <%= t.cell(:actions) { |customer| can?(:update, customer) ? link_to("Edit", edit_customer_path(customer), class: "font-medium text-accent hover:opacity-80", data: { turbo_frame: "_top", turbo_prefetch: true }) : nil } %>
    <% end %>
  </div>
</div>
