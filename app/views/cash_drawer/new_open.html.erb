<% content_for :title, "Open Register" %>

<% content_for :breadcrumbs do %>
  <li><%= link_to "Dashboard", root_path, class: "text-muted hover:text-body transition-colors" %></li>
  <li aria-hidden="true" class="flex items-center text-muted/40"><svg class="h-3 w-3" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"/></svg></li>
  <li><%= link_to "Cash Drawer", cash_drawer_path, class: "text-muted hover:text-body transition-colors" %></li>
  <li aria-hidden="true" class="flex items-center text-muted/40"><svg class="h-3 w-3" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"/></svg></li>
  <li aria-current="page" class="text-body font-medium">Open Register</li>
<% end %>

<div class="mx-auto max-w-2xl">
  <%= render "shared/page_header", title: "Open Register", description: "Count the cash currently in the drawer to open the register." %>

  <% if @session.errors.any? %>
    <div class="mt-2 rounded-lg border border-(--color-error-border) bg-(--color-error-bg) px-3 py-2">
      <p class="text-sm font-semibold text-(--color-error-text)">Please fix the following:</p>
      <ul class="mt-1 list-disc space-y-0.5 pl-5 text-sm text-(--color-error-text)">
        <% @session.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%= form_with url: open_cash_drawer_path, method: :post, class: "mt-3" do %>
    <%= render "denomination_form", action_path: open_cash_drawer_path, submit_label: "Open Register", existing_counts: {} %>

    <div class="mt-3 flex items-center justify-end gap-2">
      <%= link_to "Cancel", cash_drawer_path,
          class: "inline-flex min-h-[30px] items-center justify-center rounded-md border border-theme bg-surface px-2.5 py-1 text-sm font-medium text-body hover:bg-[var(--color-border)]/30" %>
      <button type="submit"
              class="inline-flex min-h-7.5 items-center justify-center rounded-md bg-accent px-3 py-1.5 text-sm font-semibold text-(--color-page) hover:bg-(--color-accent-hover)">
        Open Register
      </button>
    </div>
  <% end %>
</div>
