<!DOCTYPE html>
<html>
  <head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <!--[if mso]>
    <style type="text/css">
      body, table, td { font-family: Inter, Arial, sans-serif !important; }
    </style>
    <![endif]-->
  </head>
  <body style="margin: 0; padding: 0; background-color: #f0f0f0; font-family: Inter, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; -webkit-font-smoothing: antialiased;">
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background-color: #f0f0f0;">
      <tr>
        <td align="center" style="padding: 40px 16px;">
          <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="max-width: 520px;">
            <!-- Header -->
            <tr>
              <td align="center" style="padding-bottom: 24px;">
                <table role="presentation" cellpadding="0" cellspacing="0">
                  <tr>
                    <td style="background-color: #0d9488; border-radius: 8px; width: 44px; height: 44px; text-align: center; vertical-align: middle;">
                      <span style="color: #ffffff; font-size: 18px; font-weight: 700; letter-spacing: -0.5px;">EI</span>
                    </td>
                    <td style="padding-left: 12px;">
                      <span style="font-size: 18px; font-weight: 600; color: #1a1a1a;">Point of Sale</span>
                    </td>
                  </tr>
                </table>
              </td>
            </tr>
            <!-- Content card -->
            <tr>
              <td style="background-color: #ffffff; border-radius: 12px; border: 1px solid #e0e0e0; padding: 32px;">
                <%= yield %>
              </td>
            </tr>
            <!-- Footer -->
            <tr>
              <td align="center" style="padding: 24px 0 0 0;">
                <p style="margin: 0; font-size: 12px; color: #999999; line-height: 16px;">
                  This is an automated message from Point of Sale.
                </p>
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
